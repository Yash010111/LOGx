# Dockerfile for LOGx Flask App
# Hugging Face Inference API — no GPU or heavy ML libraries needed

FROM python:3.12-slim

# Set working directory
WORKDIR /app

# Install system dependencies (needed for pandas/fpdf)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy and install Python dependencies first (layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the rest of the project
COPY . .

# Render uses port 10000 by default
EXPOSE 10000

# Production settings
ENV FLASK_ENV=production
ENV PYTHONUNBUFFERED=1

# Start with gunicorn
# --timeout 120 gives the HF API enough time to respond
# --workers 2 handles concurrent requests without overloading free tier
CMD ["gunicorn", "--bind", "0.0.0.0:10000", "--workers", "2", "--timeout", "120", "dashboard:app"]