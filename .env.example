# ============================================================================
# LOGx Environment Configuration Template
# ============================================================================
# Rename this file to .env and fill in your values
# DO NOT commit .env to version control (already in .gitignore)
# ============================================================================

# REQUIRED: Hugging Face API Token
# Get token from: https://huggingface.co/settings/tokens
# Make sure you have accepted Gemma 2B model license on HuggingFace
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OPTIONAL: Flask Configuration
# ============================================================================

# Environment mode
FLASK_ENV=development
FLASK_DEBUG=True

# Secret key for sessions (generate random value for production)
SECRET_KEY=change-this-to-a-random-secret-key

# Flask host and port
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# ============================================================================
# OPTIONAL: Device Configuration
# ============================================================================

# Use GPU (CUDA) or CPU
# DEVICE=cuda:0        # Use GPU (recommended)
# DEVICE=cpu          # Use CPU (slower but works)

# ============================================================================
# OPTIONAL: Model Configuration
# ============================================================================

# Model parameters (modify in dashboard.py for production)
# MODEL_NAME=google/gemma-2b-it
# MAX_TOKENS_SINGLE=400
# MAX_TOKENS_REPORT=700
# TEMPERATURE=0.3

# ============================================================================
# OPTIONAL: Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file location
LOG_FILE=logs/app.log

# ============================================================================
# Notes:
# - Always use HTTPS in production
# - Never share your HF_TOKEN
# - Use strong SECRET_KEY in production
# - Monitor memory usage on low-resource systems
# ============================================================================
